@{
    ViewBag.Title = "Login";
}
<!DOCTYPE html>


<html>
 <head>
     <meta name="viewport" content="width=device-width" />
     <title>众创网-登录</title>
     <link rel="shortcut icon" type="image/x-icon" href="/Resources/logo.ico" />
     <link href="/Css/DivCenter.css" rel="stylesheet" />
     <link href="/Css/LoginAndRegist.css" rel="stylesheet" />   
     <script src="/Js/jquery-3.2.1.js"></script>
     <script src="/Js/ChangeCode.js"></script>
     <link href="/Css/Common.css" rel="stylesheet" />
     
 </head>
    <body style="background-image:url(@ViewData["LoginImg"])" title="Welcom to Login">       
        <div class="lr">
            @Html.ActionLink("注册", "Regist", "User")
            @Html.ActionLink("重置密码", "ReSetPwd", "User")
            @Html.ActionLink("首页","Index","Home")
        </div>

        <div class="divCenter">
            <img  src="/Resources/head.jpg" style="margin-top:20px;" />
            @using (Html.BeginForm()) 
            {
                <form>
                  <table>
                    <tr><td>用户名：</td><td><input type="text" name="UName" /> </td></tr>
                    <tr><td>密码：</td><td><input type="password" name="UPwd" /> </td></tr>
                    <tr>
                        <td colspan="2"><input type="submit" title="Login" value="登录" /><img class="code" title="看不清?换一张" src="/User/ValidateCode" /><input type="text" name="code" style="width:90px;"  /> <br /> <span style="color:red">@ViewData["result"]</span></td>
                    </tr>
                  </table>
                </form>
               
            }
           
        </div>
       
        

        
    </body>
</html>


